# A generated secret for Payload (use the same value as the Worker secret in production)
PAYLOAD_SECRET=499f5d3d4df0407f84189100bc51372fedc4022033e10d051e67776a6b1a3faf

# Public site URL (set on the Worker as a plain variable in production for admin cookies / redirects)
# PAYLOAD_PUBLIC_SERVER_URL=https://your-worker.workers.dev

# Optional: default admin browser tab brand when admin-branding global has no brandName (NEXT_PUBLIC_* is inlined at build time)
# NEXT_PUBLIC_ADMIN_BRAND_NAME=My Product

# Public middleware: hostnames (comma-separated, no scheme) that keep the static “welcome” page at `/`.
# All other hosts redirect `/` → `/en` so `primaryDomain` resolves the site on the locale home. Set on the Worker in production.
# PUBLIC_WELCOME_ROOT_HOSTS=sys.beginos.org,beginos.org
